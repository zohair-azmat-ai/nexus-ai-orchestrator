# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=nexus-ai
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://nexus:nexus_secret@localhost:5432/nexus_db

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
