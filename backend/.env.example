# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=nexus-ai
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://nexus:nexus_secret@localhost:5432/nexus_db

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=nexus_documents

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── RAG ─────────────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_MIN_SCORE=0.4

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
