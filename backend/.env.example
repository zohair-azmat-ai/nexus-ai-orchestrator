# Application
APP_NAME=nexus-ai
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

# API / CORS
# Comma-separated list. In production, set this explicitly to your frontend origin(s).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
# Required in production.
DATABASE_URL=postgresql+psycopg://nexus:nexus_secret@localhost:5432/nexus_db

# Qdrant
# Required in production.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=nexus_documents

# OpenAI
# Required in production.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_MIN_SCORE=0.4

# Memory
MEMORY_SUMMARY_TRIGGER_COUNT=10
MEMORY_RECENT_MESSAGE_LIMIT=5
MEMORY_ENABLE_LLM_SUMMARIZATION=true

# Background jobs
JOBS_INLINE_MODE=true
JOBS_MAX_CONCURRENCY=10
ENABLE_ASYNC_MEMORY_SUMMARY=false
ENABLE_ASYNC_INGEST=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Auth
# Required in production. Use a strong random secret with 32+ characters.
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_EXPIRE_SECONDS=28800

# Dev bootstrap accounts
# Keep enabled for local development only.
AUTH_BOOTSTRAP_DEV_USERS=true
AUTH_DEV_ADMIN_EMAIL=admin@nexus.local
AUTH_DEV_ADMIN_PASSWORD=AdminPass123!
AUTH_DEV_REVIEWER_EMAIL=reviewer@nexus.local
AUTH_DEV_REVIEWER_PASSWORD=ReviewerPass123!
