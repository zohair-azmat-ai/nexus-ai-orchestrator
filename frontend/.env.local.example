# Required in production. In local development this may point at the backend running on port 8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional server-side override for containerized Next.js deployments.
INTERNAL_API_BASE_URL=

# Legacy fallback supported for older local setups.
NEXT_PUBLIC_API_URL=http://localhost:8000

NEXT_PUBLIC_APP_NAME=Nexus AI
