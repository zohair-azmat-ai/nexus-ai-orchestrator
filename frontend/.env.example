# -------------------------------------------------------
# Nexus AI Frontend — Environment Variables
# -------------------------------------------------------
# Copy this file to .env.local for local development.
# On Vercel, set these as project environment variables.
# -------------------------------------------------------

# Required: URL of the Nexus AI backend API
# Local development:  http://localhost:8000
# Production (Vercel): set to your deployed backend URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: server-side API URL override for containerized deployments
# (used when frontend and backend run in the same Docker network)
INTERNAL_API_BASE_URL=
